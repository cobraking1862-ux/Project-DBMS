<Window x:Class="UniversityEventManagement.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="University Event Management - Login" 
        Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="0,0,30,30">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎓" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="University Event &amp;" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextLightBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <TextBlock Text="Competition Management" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextLightBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Login Form Section -->
        <Border Grid.Row="1" 
                Background="{StaticResource SurfaceBrush}" 
                Margin="40,-30,40,20"
                CornerRadius="20"
                Effect="{StaticResource {x:Static DropShadowEffect.Key}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
            </Border.Effect>
            
            <StackPanel Margin="40,40,40,30" VerticalAlignment="Center">
                
                <!-- Username -->
                <TextBlock Text="Username" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtUsername" 
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,20"
                         FontSize="14">
                    <TextBox.Text>
                        <Binding Path="Username" UpdateSourceTrigger="PropertyChanged"/>
                    </TextBox.Text>
                </TextBox>

                <!-- Password -->
                <TextBlock Text="Password" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtPassword" 
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,30"
                             FontSize="14"
                             PasswordChar="●"/>

                <!-- Error Message -->
                <TextBlock x:Name="txtErrorMessage" 
                           Text="" 
                           FontSize="13"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,0,0,20"/>

                <!-- Login Button -->
                <Button x:Name="btnLogin" 
                        Content="Sign In" 
                        Style="{StaticResource ModernButton}"
                        Click="BtnLogin_Click"
                        Height="50"
                        FontSize="16"/>
                
                <!-- Hint Text -->
                <TextBlock Text="Default credentials: admin / admin123" 
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" VerticalAlignment="Bottom" Margin="20,0">
            <TextBlock Text="© 2026 University Event Management System" 
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
